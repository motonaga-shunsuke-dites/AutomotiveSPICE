{
  "SWE1_SRS": {
    "label": "ソフトウェア要件仕様書",
    "process": "SWE1",
    "idPrefix": "SRS",
    "sections": [
      {
        "id": "header", "title": "基本情報",
        "fields": [
          { "id": "title",    "label": "タイトル",  "type": "text", "required": true },
          { "id": "version",  "label": "バージョン","type": "text" },
          { "id": "status",   "label": "ステータス","type": "select", "options": ["Draft","Under Review","Approved"] },
          { "id": "author",   "label": "作成者",    "type": "text" },
          { "id": "approver", "label": "承認者",    "type": "text" }
        ]
      },
      {
        "id": "purpose", "title": "目的・スコープ",
        "fields": [
          { "id": "purpose",    "label": "目的",    "type": "textarea" },
          { "id": "scope",      "label": "スコープ","type": "textarea" },
          { "id": "outOfScope", "label": "対象外",  "type": "textarea" }
        ]
      },
      {
        "id": "requirements", "title": "機能要件", "type": "itemList",
        "itemFields": [
          { "id": "id",          "label": "ID",       "type": "text", "placeholder": "SWR-001" },
          { "id": "title",       "label": "タイトル", "type": "text" },
          { "id": "description", "label": "説明",     "type": "textarea" },
          { "id": "priority",    "label": "優先度",   "type": "select", "options": ["Must","Should","Nice-to-have"] },
          { "id": "source",      "label": "根拠",     "type": "text", "placeholder": "SYS-001" },
          { "id": "acceptance",  "label": "受入基準", "type": "textarea" },
          { "id": "status",      "label": "状態",     "type": "select", "options": ["Draft","Agreed","Deleted"] }
        ]
      },
      {
        "id": "nfRequirements", "title": "非機能要件", "type": "itemList",
        "itemFields": [
          { "id": "id",          "label": "ID",     "type": "text", "placeholder": "SWR-N01" },
          { "id": "category",    "label": "種別",   "type": "select", "options": ["性能","安全","セキュリティ","信頼性","保守性"] },
          { "id": "description", "label": "要件",   "type": "textarea" },
          { "id": "target",      "label": "目標値", "type": "text" },
          { "id": "source",      "label": "根拠",   "type": "text" }
        ]
      },
      {
        "id": "issues", "title": "課題・懸念事項", "type": "itemList",
        "itemFields": [
          { "id": "id",      "label": "課題ID",   "type": "text", "placeholder": "ISS-01" },
          { "id": "content", "label": "内容",     "type": "textarea" },
          { "id": "impact",  "label": "影響範囲", "type": "text" },
          { "id": "owner",   "label": "担当者",   "type": "text" },
          { "id": "status",  "label": "状態",     "type": "select", "options": ["Open","In Progress","Closed"] }
        ]
      }
    ]
  },
  "SWE2_SAD": {
    "label": "ソフトウェアアーキテクチャ設計書",
    "process": "SWE2",
    "idPrefix": "SAD",
    "sections": [
      {
        "id": "header", "title": "基本情報",
        "fields": [
          { "id": "title",    "label": "タイトル",  "type": "text", "required": true },
          { "id": "version",  "label": "バージョン","type": "text" },
          { "id": "status",   "label": "ステータス","type": "select", "options": ["Draft","Under Review","Approved"] },
          { "id": "author",   "label": "作成者",    "type": "text" },
          { "id": "approver", "label": "承認者",    "type": "text" }
        ]
      },
      {
        "id": "overview", "title": "アーキテクチャ概要",
        "fields": [
          { "id": "policy",    "label": "設計方針",      "type": "textarea" },
          { "id": "pattern",   "label": "採用パターン",  "type": "text" },
          { "id": "contextDiagram", "label": "コンテキスト図 (テキスト)", "type": "textarea" }
        ]
      },
      {
        "id": "components", "title": "コンポーネント構成", "type": "itemList",
        "itemFields": [
          { "id": "id",           "label": "ID",          "type": "text", "placeholder": "ARC-001" },
          { "id": "name",         "label": "コンポーネント名","type": "text" },
          { "id": "responsibility","label": "責務",        "type": "textarea" },
          { "id": "relatedSWR",   "label": "担当 SWR",    "type": "text" },
          { "id": "dependencies", "label": "依存関係",    "type": "text" },
          { "id": "constraints",  "label": "制約",        "type": "textarea" }
        ]
      },
      {
        "id": "interfaces", "title": "インターフェース設計", "type": "itemList",
        "itemFields": [
          { "id": "id",        "label": "ID",      "type": "text", "placeholder": "IFC-001" },
          { "id": "provider",  "label": "提供側",  "type": "text" },
          { "id": "consumer",  "label": "消費側",  "type": "text" },
          { "id": "operation", "label": "操作名",  "type": "text" },
          { "id": "args",      "label": "引数・戻り値", "type": "textarea" },
          { "id": "frequency", "label": "呼び出し頻度","type": "text" },
          { "id": "error",     "label": "エラー処理","type": "textarea" }
        ]
      },
      {
        "id": "adr", "title": "設計決定 (ADR)", "type": "itemList",
        "itemFields": [
          { "id": "id",          "label": "ADR-ID",    "type": "text", "placeholder": "ADR-001" },
          { "id": "title",       "label": "タイトル",  "type": "text" },
          { "id": "context",     "label": "コンテキスト","type": "textarea" },
          { "id": "decision",    "label": "決定内容",  "type": "textarea" },
          { "id": "rationale",   "label": "採用理由",  "type": "textarea" },
          { "id": "alternatives","label": "却下した代替案","type": "textarea" },
          { "id": "status",      "label": "状態",      "type": "select", "options": ["Accepted","Deprecated","Superseded"] }
        ]
      }
    ]
  },
